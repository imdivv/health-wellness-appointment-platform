# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# JWT Configuration
JWT_SECRET=your_jwt_super_secret_key_change_in_production
JWT_EXPIRES_IN=1d

# Database Configuration (Azure SQL Database / MSSQL)
DB_HOST=your-database-server.database.windows.net
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_PORT=1433

# Azure Storage Configuration (Azure Blob Storage)
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_STORAGE_CONTAINER_NAME=medical-records

# Azure Communication Services (Optional for now)
AZURE_COMMUNICATION_CONNECTION_STRING=your_azure_communication_connection_string
